<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Show users page</title>
    <style>
      table,
      tr,
      th,
      td {
        border: 1px solid black;
      }
    </style>
  </head>

  <body>
<form action="/users/new" method="get"> <button>Add new user</button> </form>

    <table>
      <tr>
        <th>id</th>
        <th>username</th>
        <th>email</th>
      </tr>

      
      <%for( let usr of usrs){%>
 <tr>
  <td><%= usr.id%></td>
  <td><%= usr.username%></td>
  <td><%= usr.email%></td>

  <td>  
    <form action="/users/<%= usr.id%>/edit" method="get"> <button>Edit user</button></form> </td>

    <td><form action="/users/<%=usr.id%>?_method=DELETE  " method="POST"><button>Delete user</button></form></td>
  </tr>




<%}%>


      
    </table>
  </body>
</html>
